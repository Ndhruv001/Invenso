generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum PartyType {
  CUSTOMER
  SUPPLIER
  BOTH
  EMPLOYEE
  DRIVER
  OTHER
}

enum DriverShift {
  MORNING
  EVENING
  NIGHT
  SUNDAY
  HOLIDAY
  OTHER
}

enum UnitType {
  PCS
  METER
  KG
  LITER
  BOX
  PACKET
  ROLL
  SHEET
  SQF
  SQM
  OTHER
}

enum PaymentMode {
  NONE
  CASH
  BANK_TRANSFER
  CHEQUE
  UPI
  CARD
  CREDIT
  ONLINE
}

enum PaymentType {
  RECEIVED
  PAID
}

enum PaymentReferenceType {
  PURCHASE
  SALE
  PURCHASE_RETURN
  SALE_RETURN
  GENERAL
  TRANSPORT
  OTHER
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
  VIEWER
}

enum InventoryReferenceType {
  PURCHASE
  SALE
  PURCHASE_RETURN
  SALE_RETURN
  OPENING_STOCK
  ADJUSTMENT
  DAMAGE
  TRANSFER
  OTHER
}

enum InventoryLogType {
  ADD
  SUBTRACT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum CategoryType {
  PRODUCT
  EXPENSE
}

enum TransactionStatus {
  PAID
  PARTIAL
  UNPAID
  CANCELLED
  DRAFT
}

// Models

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      UserRole @default(STAFF)
  fullName  String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs AuditLog[]

  @@map("users")
}

model Category {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  type        CategoryType @default(PRODUCT)
  description String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  products Product[]
  expenses Expense[]

  @@map("categories")
}

model Product {
  id            Int      @id @default(autoincrement())
  name          String
  categoryId    Int
  hsnCode       String?
  unit          UnitType      @default(PCS)
  openingStock  Decimal  @default(0) @db.Decimal(10, 3)
  currentStock  Decimal  @default(0) @db.Decimal(10, 3)
  avgCostPrice  Decimal  @default(0) @db.Decimal(10, 2)
  avgSellPrice  Decimal  @default(0) @db.Decimal(10, 2)
  threshold     Decimal  @default(0) @db.Decimal(10, 2)
  description   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category            Category             @relation(fields: [categoryId], references: [id])
  inventoryLogs       InventoryLog[]
  purchaseItems       PurchaseItem[]
  saleItems           SaleItem[]
  purchaseReturnItems PurchaseReturnItem[]
  saleReturnItems     SaleReturnItem[]

  @@unique([name, categoryId])
  @@map("products")
}

model Party {
  id             Int         @id @default(autoincrement())
  name           String
  identifier     String?     // PAN/Aadhar/License
  type           PartyType
  phone          String?
  gstNumber      String?
  openingBalance Decimal     @default(0) @db.Decimal(15, 2)
  currentBalance Decimal     @default(0) @db.Decimal(15, 2)
  remark         String?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  purchases       Purchase[]
  purchaseReturns PurchaseReturn[]
  sales          Sale[]
  saleReturns    SaleReturn[]
  payments       Payment[]
  transports     Transport[] @relation("TransportParty")
  drives         Transport[] @relation("TransportDriver")

  @@map("parties")
}

model Purchase {
  id                 Int               @id @default(autoincrement())
  date               DateTime          @default(now())
  partyId            Int
  invoiceNumber      Int               
  totalAmount        Decimal           @db.Decimal(15, 2)
  totalGstAmount     Decimal           @db.Decimal(15, 2)
  totalTaxableAmount Decimal           @db.Decimal(15, 2)
  paidAmount         Decimal           @default(0) @db.Decimal(15, 2)
  paymentMode        PaymentMode       @default(NONE)
  paymentReference   String?
  remarks            String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  party           Party             @relation(fields: [partyId], references: [id])
  purchaseItems   PurchaseItem[]
  purchaseReturns PurchaseReturn[]
  payments       Payment[]          @relation("PurchasePayments")
  inventoryLogs  InventoryLog[]     @relation("PurchaseInventoryLogs")

  @@map("purchases")
}

model PurchaseItem {
  id            Int      @id @default(autoincrement())
  purchaseId    Int
  productId    Int
  quantity    Decimal       @db.Decimal(10, 3)
  pricePerUnit Decimal       @db.Decimal(10, 2)
  gstRate      Decimal       @db.Decimal(5, 2)
  gstAmount     Decimal        @db.Decimal(15, 2)
  taxableAmount Decimal       @db.Decimal(15, 2)
  amount        Decimal       @default(0) @db.Decimal(15, 2)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@map("purchase_items")
}

model PurchaseReturn {
  id                 Int               @id @default(autoincrement())
  date               DateTime          @default(now())
  partyId            Int
  purchaseId          Int?
  totalAmount        Decimal           @db.Decimal(15, 2)
  totalGstAmount     Decimal           @db.Decimal(15, 2)
  totalTaxableAmount Decimal           @db.Decimal(15, 2)
  receivedAmount     Decimal           @default(0) @db.Decimal(15, 2)
  paymentMode        PaymentMode       @default(NONE)
  paymentReference   String?
  reason             String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  party           Party             @relation(fields: [partyId], references: [id])
  purchase        Purchase?         @relation(fields: [purchaseId], references: [id])
  purchaseReturnItems PurchaseReturnItem[]
  payments        Payment[]          @relation("PurchaseReturnPayments")
  inventoryLogs   InventoryLog[]     @relation("PurchaseReturnInventoryLogs")

  @@map("purchase_returns")
}

model PurchaseReturnItem {
  id            Int      @id @default(autoincrement())
  purchaseReturnId Int
  productId    Int
  quantity    Decimal       @db.Decimal(10, 3)
  pricePerUnit Decimal       @db.Decimal(10, 2)
  gstRate      Decimal       @db.Decimal(5, 2)
  gstAmount     Decimal        @db.Decimal(15, 2)
  taxableAmount Decimal       @db.Decimal(15, 2)
  amount        Decimal       @default(0) @db.Decimal(15, 2)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  purchaseReturn PurchaseReturn @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)
  product     Product          @relation(fields: [productId], references: [id])

  @@map("purchase_return_items")
}

model Sale {
  id                 Int               @id @default(autoincrement())
  date               DateTime          @default(now())
  partyId            Int
  invoiceNumber      Int               @unique @default(autoincrement())
  totalAmount        Decimal           @db.Decimal(15, 2)
  totalGstAmount     Decimal           @db.Decimal(15, 2)
  totalTaxableAmount Decimal           @db.Decimal(15, 2)
  receivedAmount     Decimal           @default(0) @db.Decimal(15, 2)
  paymentMode        PaymentMode       @default(NONE)
  paymentReference   String?
  totalProfit        Decimal           @default(0) @db.Decimal(15, 2)
  remarks            String?
  whatsappSent       Boolean           @default(false)
  whatsappSentAt     DateTime          @default(null)
  whatsappRetryCount Int               @default(0)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  party         Party             @relation(fields: [partyId], references: [id])
  saleItems    SaleItem[]
  saleReturns SaleReturn[]
  payments    Payment[]          @relation("SalePayments")
  inventoryLogs InventoryLog[]   @relation("SaleInventoryLogs")

  @@map("sales")
}

model SaleItem {
  id            Int      @id @default(autoincrement())
  saleId        Int
  productId    Int
  quantity    Decimal      @db.Decimal(10, 3)
  pricePerUnit Decimal      @db.Decimal(10, 2)
  gstRate      Decimal      @db.Decimal(5, 2)
  gstAmount     Decimal      @db.Decimal(15, 2)
  taxableAmount Decimal      @db.Decimal(15, 2)
  amount        Decimal      @default(0) @db.Decimal(15, 2)
  profit       Decimal      @db.Decimal(15, 2) @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  sale      Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product   Product       @relation(fields: [productId], references: [id])

  @@map("sale_items")
}

model SaleReturn {
  id                 Int               @id @default(autoincrement())
  date               DateTime          @default(now())
  partyId            Int
  saleId             Int
  totalAmount        Decimal           @db.Decimal(15, 2)
  totalGstAmount     Decimal           @db.Decimal(15, 2)
  totalTaxableAmount Decimal           @db.Decimal(15, 2)
  paidAmount         Decimal           @default(0) @db.Decimal(15, 2)
  paymentMode        PaymentMode       @default(NONE)
  paymentReference   String?
  totalProfitLoss    Decimal           @default(0) @db.Decimal(15, 2)
  reason             String?
  whatsappSent       Boolean           @default(false)
  whatsappSentAt     DateTime          @default(null)
  whatsappRetryCount Int               @default(0)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  party           Party             @relation(fields: [partyId], references: [id])
  sale            Sale              @relation(fields: [saleId], references: [id])
  saleReturnItems SaleReturnItem[]
  payments       Payment[]          @relation("SaleReturnPayments")
  inventoryLogs  InventoryLog[]     @relation("SaleReturnInventoryLogs")

  @@map("sale_returns")
}

model SaleReturnItem {
  id            Int      @id @default(autoincrement())
  saleReturnId Int
  productId    Int
  quantity    Decimal       @db.Decimal(10, 3)
  pricePerUnit Decimal       @db.Decimal(10, 2)
  gstRate      Decimal       @db.Decimal(5, 2)
  gstAmount     Decimal       @db.Decimal(15, 2)
  taxableAmount Decimal       @db.Decimal(15, 2)
  amount         Decimal       @default(0) @db.Decimal(15, 2)
  profitLoss   Decimal       @db.Decimal(15, 2) @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  saleReturn SaleReturn        @relation(fields: [saleReturnId], references: [id], onDelete: Cascade)
  product    Product           @relation(fields: [productId], references: [id])

  @@map("sale_return_items")
}

model Payment {
  id               Int                  @id @default(autoincrement())
  date             DateTime             @default(now())
  partyId          Int?
  type             PaymentType
  amount           Decimal              @db.Decimal(15, 2)
  paymentReference String?
  remark           String?
  referenceType    PaymentReferenceType
  paymentMode      PaymentMode          @default(CASH)
  
  // Separate foreign keys for each reference type
  purchaseId       Int?
  saleId           Int?
  purchaseReturnId Int?
  saleReturnId     Int?
  transportId      Int?
  
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  party           Party?             @relation(fields: [partyId], references: [id])
  purchase        Purchase?          @relation("PurchasePayments", fields: [purchaseId], references: [id])
  sale            Sale?              @relation("SalePayments", fields: [saleId], references: [id])
  purchaseReturn  PurchaseReturn?    @relation("PurchaseReturnPayments", fields: [purchaseReturnId], references: [id])
  saleReturn      SaleReturn?        @relation("SaleReturnPayments", fields: [saleReturnId], references: [id])
  transport       Transport?         @relation("TransportPayments", fields: [transportId], references: [id])

  @@map("payments")
}

model Expense {
  id              Int               @id @default(autoincrement())
  categoryId      Int
  date            DateTime          @default(now())
  amount          Decimal           @db.Decimal(15, 2)
  paymentMode     PaymentMode       @default(CASH)
  paymentReference String?
  remark          String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  category        Category          @relation(fields: [categoryId], references: [id])

  @@map("expenses")
}

model Transport {
  id              Int               @id @default(autoincrement())
  partyId         Int
  date            DateTime          @default(now())
  driverId        Int
  shift           DriverShift       @default(MORNING)
  fromLocation    String
  toLocation      String
  amount          Decimal           @db.Decimal(15, 2)
  receivedAmount  Decimal           @default(0) @db.Decimal(15, 2)
  paymentMode     PaymentMode       @default(NONE)
  paymentReference String?
  remark          String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  party           Party             @relation("TransportParty", fields: [partyId], references: [id])
  driver          Party             @relation("TransportDriver", fields: [driverId], references: [id])
  payments        Payment[]         @relation("TransportPayments")

  @@map("transports")
}

model InventoryLog {
  id              Int              @id @default(autoincrement())
  productId       Int
  type            InventoryLogType  
  quantity        Decimal          @db.Decimal(10, 3)
  remark          String?
  balanceBefore    Decimal?
  balanceAfter     Decimal?
  referenceType    InventoryReferenceType  @default(SALE)
  createdAt       DateTime          @default(now())

  purchaseId       Int?
  saleId           Int?
  purchaseReturnId Int?
  saleReturnId     Int?

  product         Product         @relation(fields: [productId], references: [id])
  purchase        Purchase?       @relation("PurchaseInventoryLogs", fields: [purchaseId], references: [id])
  sale            Sale?           @relation("SaleInventoryLogs", fields: [saleId], references: [id])
  purchaseReturn  PurchaseReturn? @relation("PurchaseReturnInventoryLogs", fields: [purchaseReturnId], references: [id])
  saleReturn      SaleReturn?     @relation("SaleReturnInventoryLogs", fields: [saleReturnId], references: [id])

  @@map("inventory_logs")
}

model AuditLog {
  id              Int              @id @default(autoincrement())
  tableName       String
  recordId        String?
  action          AuditAction
  fieldName       String?
  oldValue        String?
  newValue        String?
  userId          Int?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime         @default(now())

  user            User?            @relation(fields: [userId], references: [id])

  @@index([tableName, recordId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}