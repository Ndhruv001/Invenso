// Prisma schema for Invenso Inventory Management System

// ----------------------------
// Generator & Datasource Block
// ----------------------------
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------
// Enums
// ----------------------------
enum GST {
  NONE
  GST_5
  GST_12
  GST_18
  GST_28
}

enum ExpenseCategory {
  SALARY
  RENT
  ELECTRICITY
  MAINTENANCE
  TRANSPORT
  OTHER
}

// ----------------------------
// Models
// ----------------------------

model Product {
  id                Int      @id @default(autoincrement())
  name              String
  category          Category @relation(fields: [categoryId], references: [id])
  categoryId        Int
  HSN_code          String?
  unit_of_measure   String
  avg_price         Float
  SKU               String?  @unique
  description       String?
  reorder_threshold Int      @default(0)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  purchaseItems   PurchaseItem[]
  salesItems      SalesItem[]
  stockBalances   StockOpeningBalance[]
  inventoryLogs   InventoryLog[]
  prasoACPSheets  PrasoACPSheet[]
  currentStock    CurrentStock?
  purchaseReturns PurchaseReturn[]
  salesReturns    SalesReturn[]
}

model Category {
  id          Int     @id @default(autoincrement())
  name        String
  description String?

  products Product[]
}

model Party {
  id             Int      @id @default(autoincrement())
  name           String
  type           String // supplier or customer
  gst_number     String?
  contact_number String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  purchases       Purchase[]
  sales           Sale[]
  payments        Payment[]
  openingPayments OpeningBalancePayment[]
  transportations Transportation[]
}

model StockOpeningBalance {
  id         Int      @id @default(autoincrement())
  product    Product  @relation(fields: [productId], references: [id])
  productId  Int
  quantity   Int
  unit       String
  unit_price Float
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model OpeningBalancePayment {
  id      Int      @id @default(autoincrement())
  party   Party    @relation(fields: [partyId], references: [id])
  partyId Int
  amount  Float
  type    String // credit or debit
  remarks String?
  date    DateTime
}

model Purchase {
  id           Int      @id @default(autoincrement())
  party        Party    @relation(fields: [partyId], references: [id])
  partyId      Int
  invoice_no   String
  date         DateTime
  total_amount Float
  gst          GST      @default(NONE)
  remarks      String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  items   PurchaseItem[]
  returns PurchaseReturn[]
}

model PurchaseItem {
  id         Int      @id @default(autoincrement())
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  purchaseId Int
  product    Product  @relation(fields: [productId], references: [id])
  productId  Int
  hsn        String?
  quantity   Int
  unit       String
  unit_price Float
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model PurchaseReturn {
  id         Int      @id @default(autoincrement())
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  purchaseId Int
  product    Product  @relation(fields: [productId], references: [id])
  productId  Int
  hsn        String?
  quantity   Int
  reason     String?
  date       DateTime
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model Sale {
  id           Int      @id @default(autoincrement())
  party        Party    @relation(fields: [partyId], references: [id])
  partyId      Int
  sale_date    DateTime
  total_amount Float
  total_profit Float    @default(0) // ✅ New field
  gst          GST      @default(NONE)
  remarks      String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  items   SalesItem[]
  returns SalesReturn[]
}

model SalesItem {
  id         Int      @id @default(autoincrement())
  sale       Sale     @relation(fields: [saleId], references: [id])
  saleId     Int
  product    Product  @relation(fields: [productId], references: [id])
  productId  Int
  hsn        String?
  quantity   Int
  unit       String
  unit_price Float
  profit     Float    @default(0) // ✅ New field
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model SalesReturn {
  id         Int      @id @default(autoincrement())
  sale       Sale     @relation(fields: [saleId], references: [id])
  saleId     Int
  product    Product  @relation(fields: [productId], references: [id])
  productId  Int
  hsn        String?
  quantity   Int
  reason     String?
  date       DateTime
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model InventoryLog {
  id              Int      @id @default(autoincrement())
  product         Product  @relation(fields: [productId], references: [id])
  productId       Int
  quantity_change Int
  source_type     String // sale, purchase, return, manual
  reference_id    Int?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
}

model Payment {
  id                Int      @id @default(autoincrement())
  party             Party    @relation(fields: [partyId], references: [id])
  partyId           Int
  amount            Float
  type              String // incoming/outgoing
  payment_mode      String
  payment_reference String?
  date              DateTime
  remarks           String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
}

model Expense {
  id           Int             @id @default(autoincrement())
  category     ExpenseCategory
  amount       Float
  payment_mode String
  date         DateTime
  description  String?
  created_at   DateTime        @default(now())
  updated_at   DateTime        @updatedAt
}

model Transportation {
  id             Int      @id @default(autoincrement())
  date           DateTime
  party          Party    @relation(fields: [partyId], references: [id])
  partyId        Int
  location_from  String
  location_to    String
  driver_name    String
  transport_cost Float
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
}

model User {
  id            Int       @id @default(autoincrement())
  username      String    @unique
  password_hash String
  role          String
  last_login    DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
}

model AuditLog {
  id           Int      @id @default(autoincrement())
  table_name   String
  record_id    Int
  action       String // create, update, delete
  old_value    String?
  new_value    String?
  performed_by String
  timestamp    DateTime @default(now())
}

model PrasoACPSheet {
  id          Int      @id @default(autoincrement())
  product     Product  @relation(fields: [productId], references: [id])
  productId   Int
  batch_no    String
  color_code  String
  size        String
  rack_number String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model CurrentStock {
  id        Int      @id @default(autoincrement())
  product   Product  @relation(fields: [productId], references: [id])
  productId Int      @unique
  quantity  Int
  updatedAt DateTime @updatedAt
}
